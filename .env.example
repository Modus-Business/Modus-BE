PORT=3000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,https://modus-theta.vercel.app,https://modus-student.vercel.app,https://modus-teacher.vercel.app

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=modus
DB_SYNCHRONIZE=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=replace-with-mail-user
MAIL_PASSWORD=replace-with-mail-password
MAIL_FROM=replace-with-mail-from

AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=replace-with-s3-bucket
AWS_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
AWS_S3_PUBLIC_BASE_URL=https://replace-with-public-base-url
AWS_S3_PRESIGNED_EXPIRES_IN=900

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-5-nano
